{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": [
    "src"
  ],
  "tsconfig": "tsconfig.app.json",
  "out": "docs",
  "name": "TextCraft Documentation",
  "includeVersion": true,
  "excludePrivate": true,
  "excludeProtected": true,
  "excludeExternals": true,
  "readme": "TEXTCRAFT-DOCUMENTATION-GUIDE.md",
  "theme": "default",
  "categorizeByGroup": true,
  "defaultCategory": "Other",
  "categoryOrder": [
    "Tool Components",
    "Core Infrastructure",
    "Theme Management",
    "Hooks",
    "Utilities",
    "Other"
  ],
  "sort": [
    "source-order"
  ],
  "kindSortOrder": [
    "Project",
    "Module",
    "Namespace",
    "Enum",
    "Class",
    "Interface",
    "TypeAlias",
    "Constructor",
    "Variable",
    "Function",
    "Accessor",
    "Method",
    "TypeLiteral"
  ],
  "navigation": {
    "includeCategories": true,
    "includeGroups": true
  },
  "searchInComments": true,
  "cleanOutputDir": true,
  "exclude": [
    "**/*.test.tsx",
    "**/*.test.ts",
    "**/__tests__/**",
    "**/test/**",
    "**/node_modules/**",
    "**/dist/**",
    "**/vitest.config.ts",
    "**/setup.ts"
  ],
  "externalPattern": [
    "**/node_modules/**"
  ],
  "excludeNotDocumented": false,
  "excludeInternal": true,
  "gitRevision": "main",
  "gitRemote": "origin",
  "plugin": [],
  "disableSources": false,
  "sourceLinkTemplate": "https://github.com/KrishnaSathvik/textcraft/blob/{gitRevision}/{path}#L{line}",
  "treatWarningsAsErrors": false,
  "validation": {
    "notExported": true,
    "invalidLink": true,
    "notDocumented": false
  },
  "commentStyle": "jsdoc",
  "entryPointStrategy": "expand",
  "preserveWatchOutput": true,
  "lightHighlightTheme": "github-light",
  "darkHighlightTheme": "github-dark"
}
